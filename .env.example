# Flask
FLASK_ENV=development
SECRET_KEY=your-secret-key-here
JWT_SECRET_KEY=your-jwt-secret-here

# Database (SQLite for dev, MySQL for prod)
# DATABASE_URL=mysql+mysqlconnector://user:password@localhost/simulacrum

# Claude / Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Email — set EMAIL_PROVIDER to 'smtp' or 'sendgrid'
EMAIL_PROVIDER=smtp
MAIL_DEFAULT_SENDER=noreply@simulacrum.ai

# SMTP (used when EMAIL_PROVIDER=smtp)
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your@email.com
MAIL_PASSWORD=your-app-password

# SendGrid HTTP API (used when EMAIL_PROVIDER=sendgrid)
SENDGRID_API_KEY=SG....

# LinkedIn OAuth
LINKEDIN_CLIENT_ID=your-linkedin-client-id
LINKEDIN_CLIENT_SECRET=your-linkedin-client-secret
LINKEDIN_REDIRECT_URI=http://localhost:5000/api/resumes/linkedin/callback

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:5000/api/auth/google/callback

# Redis (Celery broker)
REDIS_URL=redis://localhost:6379/0

# File uploads
UPLOAD_FOLDER=uploads

# Encryption key for OAuth tokens (AES-256, base64-encoded 32-byte key)
ENCRYPTION_KEY=your-base64-encoded-32-byte-key
